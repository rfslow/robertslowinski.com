---
import Base from '../layouts/Base.astro';
import MasonryGallery from '../components/MasonryGallery.astro';
import { travelPhotos } from '../data/photos';
---

<Base title="Travel" description="Travel photography by Robert Slowinski">
  <div class="page-title">
    <h1>Travel</h1>
    <span class="count">{travelPhotos.length} photographs</span>
  </div>
  <MasonryGallery images={travelPhotos} category="travel" extraClass="masonry--gallery" />
</Base>
