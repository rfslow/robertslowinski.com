---
import Base from '../layouts/Base.astro';
import MasonryGallery from '../components/MasonryGallery.astro';
import { lifestylePhotos } from '../data/photos';
import { getImageSize } from '../utils/getImageSize';
import path from 'node:path';

const images = lifestylePhotos.map(photo => {
  const thumbPath = path.join(
    process.cwd(),
    photo.src.replace('/images/', 'public/images/').replace('/lifestyle/', '/lifestyle/thumbs/')
  );
  const { width, height } = getImageSize(thumbPath);
  return { ...photo, width, height };
});
---

<Base title="Lifestyle" description="Lifestyle photography by Robert Slowinski">
  <div class="page-title">
    <h1>Lifestyle</h1>
    <span class="count">{images.length} photographs</span>
  </div>
  <MasonryGallery images={images} category="lifestyle" extraClass="masonry--gallery" />
</Base>
