---
import placeholders from '../data/placeholders.json';

interface Props {
  images: { src: string; alt: string; index: number; width?: number; height?: number; pinned?: boolean }[];
  category: string;
  extraClass?: string;
}
const { images, category, extraClass = '' } = Astro.props;

// Derive thumbnail path from full-size path
// e.g. /images/travel/travel-031.jpg → /images/travel/thumbs/travel-031.jpg
function thumbSrc(src: string): string {
  const parts = src.split('/');
  const filename = parts.pop();
  return [...parts, 'thumbs', filename].join('/');
}

// Look up the tiny blur-up placeholder for an image
function lqip(src: string): string {
  const key = src.replace('/images/', '');
  return (placeholders as Record<string, string>)[key] ?? '';
}

// Only the first ~10 images (roughly what's visible on arrival) load immediately.
// Everything else loads just-in-time as it scrolls toward the viewport.
const EAGER_COUNT = 10;
---

<div class={`masonry ${extraClass}`} id="gallery">
  {images.map((img) => {
    const eager = img.index < EAGER_COUNT;
    const thumb = thumbSrc(img.src);
    return (
      <div
        class="masonry-item"
        data-index={img.index}
        data-src={img.src}
        data-alt={img.alt}
        data-pinned={img.pinned ? 'true' : undefined}
        tabindex="0"
        role="button"
        aria-label={`Open ${img.alt} in lightbox`}
      >
        <div class="lqip" style={`background-image:url(${lqip(img.src)})`}></div>
        <img
          class="photo"
          src={eager ? thumb : undefined}
          data-thumb={eager ? undefined : thumb}
          alt={img.alt}
          width={img.width}
          height={img.height}
          decoding="async"
          fetchpriority={img.index < 5 ? 'high' : undefined}
          onload="this.classList.add('loaded')"
        />
      </div>
    );
  })}
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lb-btn close" id="lb-close" aria-label="Close">Close ✕</button>

  <div class="lb-img-wrap">
    <img id="lb-img" src="" alt="" />
  </div>

  <div class="lb-bar">
    <button class="lb-btn" id="lb-prev" aria-label="Previous image">← Prev</button>
    <div>
      <div class="lb-counter" id="lb-counter"></div>
      <div class="lb-hint">← → arrow keys · Esc to close</div>
    </div>
    <button class="lb-btn" id="lb-next" aria-label="Next image">Next →</button>
  </div>
</div>

<script>
  // Module-level state so document-level listeners (added once) can read the
  // current page's gallery, even after client-side view transitions.
  const state = {
    items: [] as HTMLElement[],
    lightbox: null as HTMLElement | null,
    lbImg: null as HTMLImageElement | null,
    lbCounter: null as HTMLElement | null,
    current: 0,
    total: 0,
    reqId: 0,
    currentCols: 0,
    resizeBound: false,
  };

  function preload(index: number) {
    if (!state.items.length) return;
    const i = (index + 1) % state.total;
    const link = document.createElement('link');
    link.rel = 'prefetch';
    link.as = 'image';
    link.href = state.items[i].dataset.src!;
    document.head.appendChild(link);
  }

  function openLightbox(index: number) {
    state.current = index;
    updateLightbox();
    state.lightbox!.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    document.getElementById('lb-close')!.focus();
    preload(index);
  }

  function closeLightbox() {
    state.lightbox!.classList.remove('is-open');
    document.body.style.overflow = '';
    state.items[state.current]?.focus();
  }

  function toThumb(src: string): string {
    const parts = src.split('/');
    const file = parts.pop();
    return [...parts, 'thumbs', file].join('/');
  }

  function updateLightbox() {
    const item = state.items[state.current];
    const fullSrc = item.dataset.src!;
    const reqId = ++state.reqId;
    state.lbImg!.alt = item.dataset.alt!;

    // Show the already-cached thumbnail instantly — correct image, no stale
    // remnant of the previously-viewed photo, no blank flash.
    state.lbImg!.src = toThumb(fullSrc);
    state.lbImg!.style.opacity = '1';

    // Then load the full-resolution version and swap it in when ready,
    // but only if the user hasn't navigated to a different image meanwhile.
    const full = new Image();
    full.onload = () => {
      if (reqId === state.reqId) state.lbImg!.src = fullSrc;
    };
    full.src = fullSrc;

    state.lbCounter!.textContent = `${state.current + 1} / ${state.total}`;
  }

  function prevImage() { state.current = (state.current - 1 + state.total) % state.total; updateLightbox(); preload(state.current); }
  function nextImage() { state.current = (state.current + 1) % state.total; updateLightbox(); preload(state.current); }

  // Fisher-Yates shuffle (in place)
  function shuffle<T>(arr: T[]): T[] {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  // Pinned photos shuffled to the front (so they vary each load but stay up top),
  // everything else in its curated order.
  function orderItems(items: HTMLElement[]): HTMLElement[] {
    const pinned = items.filter(i => i.dataset.pinned === 'true');
    const rest   = items.filter(i => i.dataset.pinned !== 'true');
    shuffle(pinned);
    return [...pinned, ...rest];
  }

  // Column count by viewport width — mirrors the CSS breakpoints.
  function getCols(gallery: HTMLElement): number {
    const w = window.innerWidth;
    const isGallery = gallery.classList.contains('masonry--gallery');
    if (isGallery) return w > 1400 ? 4 : w > 700 ? 3 : w > 480 ? 2 : 1;
    return w > 1400 ? 5 : w > 1000 ? 4 : w > 700 ? 3 : w > 480 ? 2 : 1;
  }

  function aspectRatio(item: HTMLElement): number {
    const img = item.querySelector('img');
    const w = parseFloat(img?.getAttribute('width') || '0');
    const h = parseFloat(img?.getAttribute('height') || '0');
    return (w > 0 && h > 0) ? h / w : 0.66;
  }

  // True masonry: place each photo in the currently-shortest column, in order.
  // This fills the TOP ROW first, so the leading (pinned) photos land at the top.
  function layout(gallery: HTMLElement) {
    const cols = getCols(gallery);
    state.currentCols = cols;
    const colEls: HTMLElement[] = [];
    const colHeights = new Array(cols).fill(0);
    const frag = document.createDocumentFragment();
    for (let c = 0; c < cols; c++) {
      const col = document.createElement('div');
      col.className = 'masonry-col';
      colEls.push(col);
      frag.appendChild(col);
    }
    for (const item of state.items) {
      let min = 0;
      for (let c = 1; c < cols; c++) if (colHeights[c] < colHeights[min]) min = c;
      colEls[min].appendChild(item);
      colHeights[min] += aspectRatio(item) + 0.04; // approximate gap
    }
    gallery.replaceChildren(frag);
  }

  function setupGallery() {
    const gallery = document.getElementById('gallery');
    if (!gallery) return;

    const sourceItems = Array.from(gallery.querySelectorAll('.masonry-item')) as HTMLElement[];
    state.items     = orderItems(sourceItems);
    state.lightbox  = document.getElementById('lightbox');
    state.lbImg     = document.getElementById('lb-img') as HTMLImageElement;
    state.lbCounter = document.getElementById('lb-counter');
    state.total     = state.items.length;
    state.current   = 0;

    // Switch from CSS columns to JS flex-masonry, then lay out.
    gallery.classList.add('masonry--js');
    gallery.classList.add('reveal-on');
    layout(gallery);

    // Re-layout on resize when the column count changes (bound once).
    if (!state.resizeBound) {
      state.resizeBound = true;
      let t: number;
      window.addEventListener('resize', () => {
        clearTimeout(t);
        t = window.setTimeout(() => {
          const g = document.getElementById('gallery');
          if (g && getCols(g) !== state.currentCols) layout(g);
        }, 150);
      });
    }

    // ── Blur-up: mark already-loaded (eager/cached) images as loaded ──
    state.items.forEach(item => {
      const img = item.querySelector('img.photo') as HTMLImageElement;
      if (img && img.getAttribute('src') && img.complete) img.classList.add('loaded');
    });

    if ('IntersectionObserver' in window) {
      // Observer 1: just-in-time loading. Fires ~500px before a tile is visible
      // so the photo is ready by the time you scroll to it. Only visible-ish
      // images ever get fetched — not all 80+ at once.
      const loadObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const img = entry.target.querySelector('img.photo') as HTMLImageElement;
          if (img && img.dataset.thumb && !img.getAttribute('src')) {
            img.src = img.dataset.thumb;
            if (img.complete) img.classList.add('loaded');
          }
          loadObserver.unobserve(entry.target);
        });
      }, { rootMargin: '500px 0px', threshold: 0 });

      // Observer 2: reveal animation, fires right as the tile enters view.
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });

      state.items.forEach(item => { loadObserver.observe(item); revealObserver.observe(item); });
    } else {
      // No IntersectionObserver — load and show everything
      state.items.forEach(item => {
        const img = item.querySelector('img.photo') as HTMLImageElement;
        if (img && img.dataset.thumb && !img.getAttribute('src')) img.src = img.dataset.thumb;
        item.classList.add('in-view');
      });
    }

    // ── Click / keyboard to open (per-page elements, safe to re-bind) ──
    state.items.forEach((item, i) => {
      item.addEventListener('click', () => openLightbox(i));
      item.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLightbox(i); }
      });
    });

    document.getElementById('lb-close')!.addEventListener('click', closeLightbox);
    document.getElementById('lb-prev')!.addEventListener('click', prevImage);
    document.getElementById('lb-next')!.addEventListener('click', nextImage);
    state.lightbox!.addEventListener('click', (e) => { if (e.target === state.lightbox) closeLightbox(); });

    // Touch/swipe
    let touchStartX = 0;
    state.lightbox!.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    state.lightbox!.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) { dx < 0 ? nextImage() : prevImage(); }
    });
  }

  // Document-level keyboard nav — added ONCE, reads current state.
  if (!(window as any).__galleryKeysBound) {
    (window as any).__galleryKeysBound = true;
    document.addEventListener('keydown', (e) => {
      if (!state.lightbox || !state.lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape')     closeLightbox();
      if (e.key === 'ArrowLeft')  prevImage();
      if (e.key === 'ArrowRight') nextImage();
    });
  }

  // Run on first load AND after every view transition.
  document.addEventListener('astro:page-load', setupGallery);
</script>
